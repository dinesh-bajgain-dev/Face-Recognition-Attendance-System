# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://database_user:your_password@localhost:5432/database_name

# ── Recognition ───────────────────────────────────────────────────────────
RECOGNITION_THRESHOLD=0.70
FRAME_SKIP=2

# ── Email — BREVO (free: 100 emails/day) ───────────────────────────────
# 1. Sign up at https://brevo.com (free, no credit card)
# 2. Settings → Sender Authentication → verify your sender email
# 3. Settings → API Keys → create a key with "Mail Send" permission
# 4. Paste values below:
BREVO_API_KEY=xyour_brevo_api_key_here
BREVO_FROM=sender@gmail.com